# 复制为 .env 并填入真实值
# 随机生成 SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-in-production

# 可选：直接指定完整数据库连接串（会覆盖下面的 MYSQL_* 单独变量）
# DATABASE_URL=mysql+asyncmy://user:password@host:3306/dbname

# MySQL 连接
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=gamecluster
MYSQL_USER=gamecluster
MYSQL_PASSWORD=your_password_here

# Redis 连接
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
